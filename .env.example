
# NEPS Backend Environment Configuration
# Copy this file to .env and fill in real values as needed

# Application
APP_NAME=NEPS Digital Backend
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true

# Database (for local development)
DATABASE_USER=neps
DATABASE_PASSWORD=neps_password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=neps_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Database (for Docker secrets - use these in production)
# DATABASE_USER_FILE=/run/secrets/postgres_user
# DATABASE_PASSWORD_FILE=/run/secrets/postgres_password

# REDCap
# Option 1: Use Standalone Mock REDCap API (hosted on Render)
# REDCAP_API_URL=https://your-render-mock-api.onrender.com/api
# REDCAP_API_TOKEN=mock_token_neps_2025
# REDCAP_MOCK_ENABLED=false

# Option 2: Use Embedded Mock REDCap API (runs inside this backend)
REDCAP_API_URL=http://localhost:8000/api/redcap
REDCAP_API_TOKEN=mock_token_for_development_only
REDCAP_PROJECT_ID=NEPS-2025
REDCAP_MOCK_ENABLED=true

# When real REDCap credentials are available:
# REDCAP_API_URL=https://kcird.org/api/
# REDCAP_API_TOKEN=your_real_redcap_api_token_here
# REDCAP_MOCK_ENABLED=false

# REDCap (for Docker secrets - use these in production)
# REDCAP_API_TOKEN_FILE=/run/secrets/redcap_api_token

# Security & Authentication
SECRET_KEY=your_secure_secret_key_here_change_this_in_production
# SECRET_KEY_FILE=/run/secrets/app_secret_key
JWT_ALGORITHM=ES256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
